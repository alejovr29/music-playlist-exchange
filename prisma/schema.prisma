generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  name      String?
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())

  // A user can have many playlists
  playlists Playlist[]

  // A user can vote many songs
  votes Vote[]

  // A user can choose many genres
  genres UserGenre[]

  // Social system (followers)
  following Follow[] @relation("Follower")
  followers Follow[] @relation("Following")
}

model Song {
  id          Int       @id @default(autoincrement())
  title       String
  artist      String
  album       String?
  imageUrl    String?
  externalUrl String
  createdAt   DateTime  @default(now())

  // A song can appear in many playlists
  playlists PlaylistSong[]

  // A song can belong to many genres
  genres SongGenre[]

  // A song can receive many votes
  votes Vote[]
}

model Playlist {
  id        Int       @id @default(autoincrement())
  name      String
  userId    Int
  createdAt DateTime  @default(now())
  isPublic  Boolean   @default(false)

  // Owner of the playlist
  user User @relation(fields: [userId], references: [id])

  // Songs inside the playlist
  songs PlaylistSong[]
}

model PlaylistSong {
  playlistId Int
  songId     Int

  playlist Playlist @relation(fields: [playlistId], references: [id])
  song     Song     @relation(fields: [songId], references: [id])

  @@id([playlistId, songId])
}

model Genre {
  id   Int    @id @default(autoincrement())
  name String @unique

  // Songs that belong to this genre
  songs SongGenre[]

  // Users that have chosen this genre
  users UserGenre[]
}

model SongGenre {
  songId  Int
  genreId Int

  song  Song  @relation(fields: [songId], references: [id])
  genre Genre @relation(fields: [genreId], references: [id])

  @@id([songId, genreId])
}

model UserGenre {
  userId  Int
  genreId Int
  weight  Int?
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  genre Genre @relation(fields: [genreId], references: [id])

  @@id([userId, genreId])
}

model Vote {
  id     Int @id @default(autoincrement())
  userId Int
  songId Int

  value  Int

  user User @relation(fields: [userId], references: [id])
  song Song @relation(fields: [songId], references: [id])

  @@unique([userId, songId])
}

model Follow {
  followerId  Int
  followingId Int

  follower  User @relation("Follower", fields: [followerId], references: [id])
  following User @relation("Following", fields: [followingId], references: [id])

  @@id([followerId, followingId])
}



